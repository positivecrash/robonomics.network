header(role='banner')
	#header-top
		.secw-base
			.header-top__sec
				a(href="#")#header-top__logo: img(alt="", src="assets/i/logo-robonomics.svg")
			.header-top__sec
				nav.header-top__nav
					a(href="#") Robonomics OS
					.dropdown
						a(href="#") Join us
						.dropdown-content
							a(href="#", target="_blank") telegram
					.dropdown
						a(href="#") RU
						.dropdown-content
							a(href="#", target="_blank") telegram

	#header-mid
		#header-mid__content
			img#logo-robonomics(alt="", src="assets/i/logo-robonomics.svg")
			img#logo-ethereum(alt="", src="assets/i/logo-ethereum.svg")

			.secw-base
				#header-title: span ПЛАТФОРМА РОБОНОМИКИ
				#header-subtitle { Инфраструктура сети Ethereum для умных фабрик и городов }

		#header-canvas-wrap
			svg#header-canvas