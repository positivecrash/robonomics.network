extends extends/layout_index.pug

block head
	- var pageTitle = 'Robot economic infrastructure'

block content
	main(role="main")
		section.sec-dark.sec-colored.contentBlock-about
			.secw-base
				.row
					.col-sm-6
						a(href="#").block-video
						.block-white.text-hyphened
							img.img-block(alt="", src="assets/i/about-1.png", srcset="assets/i/about-1@2x.png")
