extends extends/layout.pug

block head
	- var pageTitle = 'Robot economic infrastructure'
	- var bodyclass = 'step-2'

include includes/sections.pug

block content
	header(role='banner')
		.secw-narrow
			+header()

	main(role="main")

		.secw-narrow
			h2 1. LIGHTHOUSE INFO
			section.sec-white
				table
					tbody
						tr
							td contract of lighthouse
							td balance
							td workers
						tr
							td
								p.t-break 0xc2f821d99f469d5818ce368543bcd9389e4e04c1
							td 1000 XRT
							td 3

			h2 2. YOUR ACCOUNT
			section.sec-white
				.d-t
					.d-t_cell Your balance: 
						b 0 XRT
					.d-t_cell
						a(href="https://robonomics.network/faucet/", target="_blank") Get XRT in faucet
						button Approve
						button(disabled) Approved

			h2 3. TRY LIGHTHOUSE
			section.sec-white.step-2-actions
				.d-t.secw-full
					.d-t_cell
						img.img-block(alt="", src="assets/i/step-2-demand.jpg", srcset="assets/i/step-2-demand@2x.jpg")
						button SEND A DEMAND
					.d-t_cell
						img.img-block(alt="", src="assets/i/step-2-offer.jpg", srcset="assets/i/step-2-offer@2x.jpg")
						button SEND AN OFFER

			h2 4. WATCH MARKET
