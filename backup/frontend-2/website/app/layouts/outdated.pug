extends extends/layout_simple.pug

block html
	- var bodyclass = 'page-outdated'

block content
	#page-outdated__content
		img.img-block(alt="", src="assets/i/outdated@2x.png")

		h2 ОЙ-ОЙ! КАЖЕТСЯ, ВАШ БРАУЗЕР НЕ МОЖЕТ ОТКРЫТЬ ROBONOMICS.NETWORK
		p.t-center.t-mid Чтобы посмотреть полную версию сайта, обновите, пожалуйста, свой браузер или скачайте другой:
		.d-t
			a(target="_blank", href="https://www.google.com/chrome/browser/desktop/").d-t_cell: span.sprite.sprite-browsers-chrome
			a(target="_blank", href="https://www.mozilla.org/ru/firefox/new/").d-t_cell: span.sprite.sprite-browsers-firefox
			a(target="_blank", href="http://www.opera.com/ru?utm_medium=roc&utm_source=burocratik&utm_campaign=outdatedbrowser").d-t_cell: span.sprite.sprite-browsers-opera