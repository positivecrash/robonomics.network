extends extends/layout.pug
include mixins/sections.pug

block html
	- var meta_title = 'Robonomics Lighthouse'
	- var bodyclass = 'wrap-flexsols'

block content

	.sidebar
		.sidebar-in
			section.m-t-10
				img.i-block(alt="dApp logo", src="assets/i/logo-dapp-text.svg")

			section
				section
					nav
						a(href="#").active: span Lighthouses
						a(href="#"): span Statistics
						a(href="#"): span AIRA to XRT

				section
					nav
						a(href="#")
							span.sprite-basic-github.align-vertical.m-r-10
							span.align-vertical Github

						a(href="#")
							span.sprite-basic-reddit-2.align-vertical.m-r-10
							span.align-vertical Reddit

						a(href="#")
							span.sprite-basic-cursor.align-vertical.m-r-10
							span.align-vertical robonomomics.network

						a(href="#")
							span.sprite-basic-cursor.align-vertical.m-r-10
							span.align-vertical aira.life

		a.sidebar-toggle(href="#")


	.content
		.content-in
			section
				.panel-top
					.panel-top--cell
						a(href="#")
							+avatar('avatar-small align-vertical m-r-10')
							b 0x40c5...c8d3
					.panel-top--cell
						b.t-md 2,100
						span AIRA
					.panel-top--cell
						b.t-md 0
						span AIRA KYC
					.panel-top--cell
						b.t-md 0
						span XRT

			section
				.row
					.col-md-6
						section.section-color.section-color--highlight
							h2 Choose existing lighthouse

							section
								.input-radio
									input(type="radio", name="chooselighthouse", id="lighthouse1", checked)
									label(for="lighthouse1")
										b a.lighthouse.5.robonomics.eth
										.t-small 0x28f95c484ee55E6aB8A2feF72EB51bC65cdd4324
								
								hr/
								.input-radio
									input(type="radio", name="chooselighthouse", id="lighthouse2")
									label(for="lighthouse2")
										b a.lighthouse.5.robonomics.eth
										.t-small 0xD40AC7F1e5401e03D00F5aeC1779D8e5Af4CF9f1

								input.m-b-10.m-t-sec(type="text", value="a.lighthouse.5.robonomics.eth", placeholder="Name of the lighthouse",).container-full.t-align_left
								p 0xD40AC7F1e5401e03D00F5aeC1779D8e5Af4CF9f1

								a.btn-green(href="#") Connect to the network

					.col-md-6
						section.section-color.section-color--highlight
							h2 Create your own lighthouse
							.m-b-half
								label Name of the lighthouse
								br/
								input.container-full.t-align_left(type="text")
							.m-b-half
								label Minimal stake to get one quota (XRT)
								br/
								input(type="text", value="0.000001")
							.m-b-half
								label Silence timeout for provider in blocks
								br/ 
								input(type="text", value="25")
							a.btn-blue(href="#") Create lighthouse and connect to the network




