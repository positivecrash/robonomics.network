mixin panelTop()
	.panel-top
		.panel-top--cell
			a(href="#")
				+avatar('avatar-small align-vertical m-r-10')
				b 0x40c5...c8d3
		.panel-top--cell
			b 2,100
			span.t-sm AIRA
		.panel-top--cell
			b 0
			span.t-sm AIRA KYC
		.panel-top--cell
			b 0
			span.t-sm XRT

		


mixin sidebar($navActive, $multilang)
	.sidebar
		.sidebar-col.sidebar-col--sm
			.sidebar-col-in
				section
					a(href="/")
						img(alt="dApp logo", src="assets/i/logo-dapp-sign.svg")

				section
					a#sidebar-i-nav(href="javascript:;", show-onopen="#sidebar-nav1", show-onclose="#sidebar-nav0" ).sidebar-i--lg <
					if $multilang
						a(href="javascript:;", show-onopen="#sidebar-lang").sidebar-i--lg EN

				section.sidebar-col--bottom
					a(href="javascript:;",  show-onopen="#sidebar-info").sidebar-i--lg ?


		.sidebar-col.open#sidebar-nav1
			.sidebar-col-in
				section
					a(href="/")
						img(alt="dApp logo", src="assets/i/logo-dapp-text.svg")

				section
					nav.nav-vertical
						if $navActive == 1
							a(href="#").active: span Lighthouses
						else
							a(href="#"): span Lighthouses

						if $navActive == 2
							a(href="#").active: span Statistics
						else
							a(href="#"): span Statistics

						if $navActive == 3
							a(href="#").active: span AIRA to XRT
						else
							a(href="#"): span AIRA to XRT


		.sidebar-col.sidebar-col-padding.slide-right.close#sidebar-nav0
			.sidebar-col-in
				section
					nav.nav-vertical
						if $navActive == 1
							a(href="#").active: span L
						else
							a(href="#"): span L

						if $navActive == 2
							a(href="#").active: span S
						else
							a(href="#"): span S

						if $navActive == 3
							a(href="#").active: span A
						else
							a(href="#"): span A
		
		.sidebar-col.sidebar-col-padding.slide-right.close#sidebar-lang
			.sidebar-col-in
				section
					nav.nav-vertical
						a(href="#").active: span English
						a(href="#"): span Русский

		.sidebar-col.sidebar-col-padding.slide-right.close#sidebar-info
			.sidebar-col-in
				section
					nav.nav-vertical
						a(href="#")
							span.i-github.align-vertical.m-r-10
							span.align-vertical Github

						a(href="#")
							span.i-reddit.align-vertical.m-r-10
							span.align-vertical Reddit

						a(href="#")
							span.i-cursor.align-vertical.m-r-10
							span.align-vertical robonomomics.network

						a(href="#")
							span.i-cursor.align-vertical.m-r-10
							span.align-vertical aira.life





mixin avatar($class)
	img(alt="", class=$class, src="data:image/png;base64,")
