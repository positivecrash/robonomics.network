extends extends/layout.pug

block head
	- var pageTitle = 'Robot economic infrastructure'
	- var bodyclass = 'step-2'

include includes/sections.pug

block content
	header(role='banner')
		.secw-narrow
			+header_consensys2018()

	main(role="main")

		.secw-narrow
			h2 1. Choose a sensor network
			section.sec-white
				<select>
					<option disabled="disabled" value="">select one of the options</option>
					<option value="0">Airalab CPS [reputation: very good, more then 100 executed smart contracts]</option>
					<option value="1">NoName CPS [reputation: undefined, less then 10 executed smart contracts]</option>
				</select>

			h2 2. YOUR ACCOUNT
			section.sec-white
				.d-t
					.d-t_cell Your balance: 
						b 0 XRT
					.d-t_cell
						p: a(href="https://robonomics.network/faucet/", target="_blank") Get XRT in faucet
						button Approve
						button(disabled) Approved

