extends extends/layout.pug

block head
	- var pageTitle = 'Robot economic infrastructure'

block content
	header(role='banner')
		include mixins/sections.pug
		+header_top()

	main(role="main")
		section
			.secw-narrow
				h1 Robonomics.network F.A.Q.

			section.sec-contents
				.secw-narrow
					a(href="#") Perspective


			section.secw-narrow
				h2 Perspective
				p Adaptive system of distribution, control and service delivery by cyber physical systems within the context of the whole planet, which is directly available for end-user.
				h2 Range of issues
				p Humankind needs constant build-up of mass production of goods and services. All-out appliance of CPS in production, logistics and city life will allow coping with increasing complexity of supply chains of consumers with quality product. The main question in this field is to arrange common work of cyber physical systems (CPS).